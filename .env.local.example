# Supabase (obtener desde el dashboard del proyecto)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Sitio
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (opcional en dev — sin la key, los envíos son dry-run)
RESEND_API_KEY=re_...

# Google Gemini (opcional en dev — sin la key, IA opera en modo stub)
GOOGLE_GEMINI_API_KEY=AIza...

# Dropbox Sign / HelloSign (opcional en dev — sin la key, contratos en stub)
DROPBOX_SIGN_API_KEY=...

# Para tests E2E (CI usa secrets distintos)
# SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres
